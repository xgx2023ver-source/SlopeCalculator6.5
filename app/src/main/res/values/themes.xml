<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#4a6572</item>
        <item name="colorPrimaryDark">#34495e</item>
        <item name="colorAccent">#00c853</item>
        <item name="android:windowBackground">#f2f4f6</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#4a6572</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">#1a2a4a</item>
        <item name="android:statusBarColor">#1a2a4a</item>
        <item name="android:navigationBarColor">#1a2a4a</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
